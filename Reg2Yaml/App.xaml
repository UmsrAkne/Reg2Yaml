<prism:PrismApplication
    x:Class="Reg2Yaml.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <Application.Resources>
        <SolidColorBrush x:Key="DeepBackgroundBrush" Color="#252530" />
        <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#333340" />
        <SolidColorBrush x:Key="MiddleBackgroundBrush" Color="#444455" />

        <SolidColorBrush x:Key="SelectionBrush" Color="#446699" />
        <SolidColorBrush x:Key="HoverBrush" Color="#335580" />

        <SolidColorBrush x:Key="AccentBrush" Color="#00BCD4" />
        <SolidColorBrush x:Key="AccentLightBrush" Color="#4DD0E1" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0097A7" />

        <SolidColorBrush x:Key="CommonForegroundBrush" Color="#DDDDDD" />
        <SolidColorBrush x:Key="BorderBrush" Color="#999999" />

        <system:Double x:Key="CommonFontSize">16</system:Double>

    </Application.Resources>
</prism:PrismApplication>
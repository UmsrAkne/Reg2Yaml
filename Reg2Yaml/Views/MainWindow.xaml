<Window
    x:Class="Reg2Yaml.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:texts="clr-namespace:Reg2Yaml.Core.Texts"
    xmlns:viewModels="clr-namespace:Reg2Yaml.ViewModels"
    Title="{Binding Title}"
    Width="1280"
    Height="600"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    d:DesignHeight="480"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ListBox
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="0"
            Width="300"
            Background="LightGoldenrodYellow"
            ItemsSource="{Binding TextProcessorContainers}"
            SelectedItem="{Binding SelectedContainer}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type texts:TextProcessorContainer}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DisplayName}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ListBox
            Grid.Row="0"
            Grid.Column="1"
            Background="LightGreen"
            ItemsSource="{Binding SelectedContainer.TextProcessors}"
            SelectedItem="{Binding SelectedProcessor}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type texts:TextProcessor}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Caption}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ItemsControl
            Grid.Row="0"
            Grid.Column="2"
            Background="LightGray"
            ItemsSource="{Binding SelectedProcessor.Units}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type texts:TextProcessingUnit}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProcessingType}" />
                        <TextBlock Text="{Binding RegexPattern}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Background="LightCyan"
            FontSize="{StaticResource CommonFontSize}" />

        <TextBlock
            Grid.Row="1"
            Grid.Column="2"
            Background="LightSteelBlue"
            FontSize="{StaticResource CommonFontSize}" />
    </Grid>
</Window>
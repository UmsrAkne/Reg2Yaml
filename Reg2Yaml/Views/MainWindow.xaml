<Window
    x:Class="Reg2Yaml.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:texts="clr-namespace:Reg2Yaml.Core.Texts"
    xmlns:viewModels="clr-namespace:Reg2Yaml.ViewModels"
    Title="{Binding Title}"
    Width="1280"
    Height="600"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    d:DesignHeight="480"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <DockPanel
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="0">
            <Button
                Margin="3"
                Padding="3"
                Command="{Binding AddContainerCommand}"
                Content="Add Container"
                DockPanel.Dock="Bottom" />

            <ListBox
                Width="300"
                Background="LightGoldenrodYellow"
                DockPanel.Dock="Top"
                ItemsSource="{Binding TextProcessorContainers}"
                SelectedItem="{Binding SelectedContainer}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type texts:TextProcessorContainer}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DisplayName}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <DockPanel Grid.Row="0" Grid.Column="1">
            <Button
                Margin="3"
                Padding="3"
                Command="{Binding AddProcessorCommand}"
                Content="Add Processor"
                DockPanel.Dock="Bottom" />
            <ListBox
                Background="LightGreen"
                DockPanel.Dock="Top"
                ItemsSource="{Binding SelectedContainer.TextProcessors}"
                SelectedItem="{Binding SelectedProcessor}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type texts:TextProcessor}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Caption}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <ItemsControl
            Grid.Row="0"
            Grid.Column="2"
            Background="LightGray"
            ItemsSource="{Binding SelectedProcessor.Units}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type texts:TextProcessingUnit}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProcessingType}" />
                        <TextBlock Text="{Binding RegexPattern}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <DockPanel Grid.Row="1" Grid.Column="1">
            <Border
                Padding="3,10,3,5"
                Background="LightCyan"
                DockPanel.Dock="Top">
                <TextBlock
                    DockPanel.Dock="Top"
                    FontWeight="SemiBold"
                    Foreground="#555555"
                    Text="Input Text" />
            </Border>
            <TextBox Background="LightCyan" FontSize="{StaticResource CommonFontSize}" />
        </DockPanel>

        <DockPanel Grid.Row="1" Grid.Column="2">
            <Border
                Padding="3,10,3,5"
                Background="LightSteelBlue"
                DockPanel.Dock="Top">
                <TextBlock
                    DockPanel.Dock="Top"
                    FontWeight="SemiBold"
                    Foreground="#555555"
                    Text="Result" />
            </Border>
            <TextBlock Background="LightSteelBlue" FontSize="{StaticResource CommonFontSize}" />
        </DockPanel>
    </Grid>
</Window>